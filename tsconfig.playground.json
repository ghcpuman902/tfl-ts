{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["playground/**/*", "script/demoSmoke.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
